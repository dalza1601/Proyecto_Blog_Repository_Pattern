@using Proyecto_Blog.BE.Models
@model IEnumerable<ApplicationUser>

@{
    ViewData["Title"] = "Gestión de Usuarios";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-8">
            <h2 class="text-primary">Lista de usuarios</h2>
        </div>
        <div class="col-4 text-right">
            <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-primary">
                <i class="fa-solid fa-plus"></i>
                Crear nuevo usuario
            </a>
        </div>
    </div>

    <br />
    <br />

    @if (Model.Count() > 0)
    {
        <table id="tblUsers" class="table table-striped table-bordered" style="width: 100%">
            <thead>
                <tr>
                    <th>@Html.DisplayNameFor(m => m.Id)</th>
                    <th>@Html.DisplayNameFor(m => m.Name)</th>
                    <th>@Html.DisplayNameFor(m => m.Email)</th>
                    <th>Acciones</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>@user.Id</td>
                        <td>@user.Name</td>
                        <td>@user.Email</td>
                        <td>
                            @if (user.LockoutEnd == null || user.LockoutEnd < DateTime.Now)
                            {
                                <a class="btn btn-success text-white" asp-action="Block" asp-route-userId="@user.Id">
                                    <i class="fa fa-unlock-alt"></i>
                                </a>
                            }
                            else
                            {
                                <a class="btn btn-danger text-white" asp-action="UnBlock" asp-route-userId="@user.Id">
                                    <i class="fa fa-lock"></i>
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

</div>

@section Scripts {
    <script src="https://cdn.datatables.net/2.0.0/js/dataTables.min.js"></script>

}

@section CSS {
    <link rel="stylesheet" href="https://cdn.datatables.net/2.0.0/css/dataTables.dataTables.min.css" />
}